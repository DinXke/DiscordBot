TELEGRAM_BOT_TOKEN=your_bot_token_here
PA_TELEGRAM_BOT_TOKEN=your_personalassistant_bot_token_here
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_home_assistant_long_lived_token
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Paperclip integration (optional — enables bot to manage Paperclip issues/agents)
# Generate with: npx paperclipai agent local-cli <agent-id> --company-id <company-id>
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_COMPANY_ID=your_company_id_here
PAPERCLIP_API_KEY=your_paperclip_agent_api_key_here

# Discord webhooks (optioneel — voor uitgaande berichten naar Discord-kanalen)
# Maak webhooks aan via Discord Serverinstellingen → Integraties → Webhooks
DISCORD_WEBHOOK_ENERGIE=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_AGENTS=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_HUISJE=https://discord.com/api/webhooks/...
